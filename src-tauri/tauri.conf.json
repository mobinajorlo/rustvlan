{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RustNet",
  "version": "0.1.0",
  "identifier": "com.rustnet.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "npx vite build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RustNet • Virtual LAN Adapter Simulator",
        "width": 1150,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
